function askOption(string $question, array $options, string $default): string
{
    $optionsStr = implode('/', $options);
    echo "  {$question} [{$optionsStr}] (default: {$default}): ";

    $input = trim(fgets(STDIN));
    $input = $input ?: $default;

    if (!in_array(strtoupper($input), array_map('strtoupper', $options))) {
        return $default;
    }

    return strtoupper($input);
}

function removeFrontend(string $basePath): array
{
    $removed = [];

    $frontendPath = $basePath . '/frontend';
    if (is_dir($frontendPath)) {
        recursiveDelete($frontendPath);
        $removed[] = 'frontend/';
        echo "  ✓ Removed frontend directory\n";
    }

    $viteConfig = $basePath . '/vite.config.js';
    if (file_exists($viteConfig)) {
        unlink($viteConfig);
        $removed[] = 'vite.config.js';
        echo "  ✓ Removed vite.config.js\n";
    }

    $packageJson = $basePath . '/package.json';
    if (file_exists($packageJson)) {
        unlink($packageJson);
        $removed[] = 'package.json';
        echo "  ✓ Removed package.json\n";
    }

    return $removed;
}

function configureFrontend(string $basePath, string $framework): array
{
    $removed = [];
    $frontendDir = $basePath . '/frontend';

    // Ensure frontend directory exists
    if (!is_dir($frontendDir)) {
        mkdir($frontendDir, 0755, true);
    }

    $frameworkName = match($framework) {
        'A' => 'Vue.js',
        'B' => 'React',
        'C' => 'Svelte',
        default => 'None'
    };

    // Generate framework-specific index.html
    $htmlContent = getFrontendTemplate($framework, $frameworkName);
    file_put_contents($frontendDir . '/index.html', $htmlContent);

    echo "  ✓ Frontend configured: {$frameworkName}\n";

    return $removed;
}

