function serveAlwaysAlive(string $basePath, string $phpIni): void
{
    echo "\n";
    echo "========================================\n";
    echo "   LYGER SERVER v0.1\n";
    echo "   Always-Alive Mode\n";
    echo "========================================\n\n";

    $libPath = findLibrary($basePath);

    if ($libPath && extension_loaded('ffi')) {
        try {
            echo "Starting Rust HTTP server...\n";
        } catch (\Throwable $e) {
            echo "Error: {$e->getMessage()}\n";
        }
    }

    echo "Loading framework into memory...\n";
    require_once $basePath . '/vendor/autoload.php';
    require_once $basePath . '/Lyger/Core/ServerManager.php';

    $router = function(string $uri, string $method, array $data) {
        if ($uri === '/api/health') {
            return json_encode(['status' => 'ok', 'memory' => memory_get_usage(true) / 1024 / 1024 . ' MB']);
        }
        if ($uri === '/api/info') {
            return json_encode([
                'framework' => 'Lyger v0.1',
                'mode' => 'always-alive',
                'php_version' => PHP_VERSION,
            ]);
        }
        return json_encode(['error' => 'Not Found', 'uri' => $uri]);
    };

    \Lyger\Core\ServerManager::start($router);
}

function serveLegacy(string $basePath, string $phpIni): void
{
    $publicPath = $basePath . '/public';
    $iniFlag = file_exists($phpIni) ? "-c {$phpIni}" : '';

    echo "\n[Lyger] PHP Server running on http://localhost:8000\n";
    echo "   Press Ctrl+C to stop\n\n";

    chdir($publicPath);
    passthru("php {$iniFlag} -S localhost:8000");
}

function findLibrary(string $basePath): ?string
{
    $libNames = [
        'Darwin' => ['liblyger.dylib', 'liblyger.so'],
        'WINNT' => ['liblyger.dll'],
    ];
    $names = $libNames[PHP_OS] ?? ['liblyger.so', 'liblyger.dylib'];

    $paths = [
        $basePath . '/libraries',
        $basePath . '/target/release',
    ];

    foreach ($paths as $path) {
        foreach ($names as $name) {
            if (file_exists($path . '/' . $name)) {
                return $path . '/' . $name;
            }
        }
    }
    return null;
}

