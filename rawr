function cleanupDatabase(string $basePath, string $selected): array
{
    $removed = [];

    if ($selected === 'A') {
        echo "  ✓ Database set to: PostgreSQL\n";
    } elseif ($selected === 'B') {
        echo "  ✓ Database set to: MySQL\n";
    } elseif ($selected === 'C') {
        echo "  ✓ Database set to: SQLite\n";
    }

    return $removed;
}

function cleanupAuth(string $basePath, string $selected): array
{
    $removed = [];

    if ($selected === 'A') {
        echo "  ✓ Auth set to: Lyger Session (Rust)\n";
    } elseif ($selected === 'B') {
        echo "  ✓ Auth set to: JWT\n";
    } elseif ($selected === 'C') {
        $authController = $basePath . '/App/Controllers/AuthController.php';
        if (file_exists($authController)) {
            unlink($authController);
            $removed[] = 'App/Controllers/AuthController.php';
            echo "  ✓ Removed AuthController (No auth selected)\n";
        }
    }

    return $removed;
}

function updateEnv(string $basePath, string $database): void
{
    $dbMap = ['A' => 'pgsql', 'B' => 'mysql', 'C' => 'sqlite'];
    $db = $dbMap[$database] ?? 'sqlite';

    $envPath = $basePath . '/.env';
    if (file_exists($envPath)) {
        $env = file_get_contents($envPath);
        if (preg_match('/^DB_CONNECTION=.*$/m', $env)) {
            $env = preg_replace('/^DB_CONNECTION=.*$/m', "DB_CONNECTION={$db}", $env);
        } else {
            $env .= "\nDB_CONNECTION={$db}\n";
        }
        file_put_contents($envPath, $env);
        echo "  ✓ Updated .env (DB_CONNECTION={$db})\n";
    }
}

function recursiveDelete(string $path): void
{
    if (!is_dir($path)) return;

    $items = scandir($path);
    foreach ($items as $item) {
        if ($item === '.' || $item === '..') continue;

        $fullPath = $path . '/' . $item;
        if (is_dir($fullPath)) {
            recursiveDelete($fullPath);
        } else {
            @unlink($fullPath);
        }
    }

    @rmdir($path);
}

// ============================================================
// Zero-Bloat: Remove install command after setup
// ============================================================

function removeInstallCommand(string $basePath, string $architecture = 'B', string $frontend = 'A', string $database = 'A', string $auth = 'C'): void
{
    $markerFile = $basePath . '/.lyger_installed';
    file_put_contents($markerFile, json_encode([
        'installed_at' => date('Y-m-d H:i:s'),
        'architecture' => $architecture,
        'frontend' => $frontend,
        'database' => $database,
        'auth' => $auth
    ]));
    echo "  ✓ Install command disabled (Zero-Bloat)\n";
}

function getProjectConfig(string $basePath): array
{
    $markerFile = $basePath . '/.lyger_installed';
    if (file_exists($markerFile)) {
        $content = file_get_contents($markerFile);
        $config = json_decode($content, true);
        if ($config) {
            return $config;
        }
    }
    return [
        'architecture' => 'B',
        'frontend' => 'A',
        'database' => 'A',
        'auth' => 'C'
    ];
}

function isProjectInstalled(string $basePath): bool
{
    return file_exists($basePath . '/.lyger_installed');
}
