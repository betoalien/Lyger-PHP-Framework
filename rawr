#!/usr/bin/env php
<?php

declare(strict_types=1);

$basePath = __DIR__;
$basePath = str_replace('\\', '/', $basePath);
$phpIni = $basePath . '/php.ini';
$isInstalled = isProjectInstalled($basePath);

if ($argc < 2) {
    echo "Lyger Framework CLI v0.1\n";
    echo "Usage: php rawr <command> [arguments]\n\n";
    echo "Commands:\n";
    if (!$isInstalled) {
        echo "  install                  Interactive Zero-Bloat installer\n";
    }
    echo "  serve                   Start Always-Alive server (Rust + PHP)\n";
    echo "  serve:php              Start PHP built-in server (legacy)\n";
    echo "  make:controller <Name>  Create a new controller\n";
    echo "  make:model <Name> [--migration]  Create a new model\n";
    echo "  make:migration <Name>  Create a new migration\n";
    echo "  make:auth            Create authentication scaffolding\n";
    echo "  make:dash [<Name>]    Create a customizable admin dashboard\n";
    echo "  migrate              Run database migrations\n";
    echo "  migrate:rollback    Rollback last migration\n";
    echo "  migrate:status      Show migration status\n";
    exit(1);
}

$command = $argv[1];
$argument = $argv[2] ?? null;
$options = array_slice($argv, 2);
$hasMigration = in_array('--migration', $options);

// Block install command if already installed
if (($command === 'install' || $command === 'init') && $isInstalled) {
    echo "Error: Project already installed. Use 'php rawr serve' to start.\n";
    exit(1);
}

switch ($command) {
    case 'install':
    case 'init':
        if (isProjectInstalled($basePath)) {
            echo "Project already installed. Run 'php rawr serve' to start.\n";
            exit(0);
        }
        installProject($basePath);
        break;
    case 'serve':
        serveAlwaysAlive($basePath, $phpIni);
        break;
    case 'serve:php':
        serveLegacy($basePath, $phpIni);
        break;
    case 'make:controller':
        makeController($basePath, $argument);
        break;
    case 'make:model':
        makeModel($basePath, $argument, $hasMigration);
        break;
    case 'make:migration':
        makeMigration($basePath, $argument);
        break;
    case 'make:auth':
        makeAuth($basePath);
        break;
    case 'make:dash':
        makeDash($basePath, $argument);
        break;
    case 'migrate':
        migrate($basePath);
        break;
    case 'migrate:rollback':
        migrateRollback($basePath);
        break;
    case 'migrate:status':
        migrateStatus($basePath);
        break;
    default:
        echo "Unknown command: {$command}\n";
        break;
}

